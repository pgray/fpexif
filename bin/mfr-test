#!/usr/bin/env bash
# Manufacturer-specific EXIF testing tool
#
# Usage:
#   ./bin/mfr-test <manufacturer> --save-baseline  # Save current state before work
#   ./bin/mfr-test <manufacturer> --check          # Check progress against baseline
#   ./bin/mfr-test <manufacturer> --vs-exiftool    # Compare against exiftool
#   ./bin/mfr-test <manufacturer> --full-report    # Full comparison report
#   ./bin/mfr-test --list-baselines                # List saved baselines
#
# Supported manufacturers: canon, nikon, sony, fujifilm, panasonic, olympus, dng

exec cargo run --features cli --bin mfr-test -- "$@"
